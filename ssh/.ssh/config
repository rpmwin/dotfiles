# Work/private hosts — keep out of repo
Include ~/.ssh/config.local

Host *
  AddKeysToAgent yes
  UseKeychain yes

# Default GitHub → personal account
Host github.com
  HostName github.com
  User git
  IdentityFile ~/.ssh/github/id_ed25519_rpmwin
  IdentitiesOnly yes
  AddKeysToAgent no
  UseKeychain no

# Personal GitHub (rpmwin)
Host github-rpmwin
  HostName github.com
  User git
  IdentityFile ~/.ssh/github/id_ed25519_rpmwin
  IdentitiesOnly yes
  AddKeysToAgent no
  UseKeychain no

# Work GitHub (iamrpm)
Host github-iamrpm
  HostName github.com
  User git
  IdentityFile ~/.ssh/github/id_ed25519_iamrpm
  IdentitiesOnly yes

# Work GitHub (iamrpm) — secure, always prompts passphrase
Host github-iamrpm-secure
  HostName github.com
  User git
  IdentityFile ~/.ssh/github/id_ed25519_iamrpm_secure
  IdentitiesOnly yes
  AddKeysToAgent no
  UseKeychain no

Host *
    SetEnv TERM=xterm-256color
