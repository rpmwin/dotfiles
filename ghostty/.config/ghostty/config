# Appearance
theme = Catppuccin Mocha
font-family = JetBrainsMono Nerd Font
font-size = 14
background-opacity = 0.95
background-blur-radius = 20
window-padding-x = 10
window-padding-y = 10

# Tabs & windows
window-decoration = true

# Behavior
confirm-close-surface = false        
mouse-hide-while-typing = true
copy-on-select = true               
scrollback-limit = 100000000

# Shell
shell-integration = zsh
shell-integration-features = cursor,sudo,title

# Cursor
cursor-style = bar
cursor-style-blink = true

# Splits (built in, no tmux needed!)
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+]=goto_split:next
keybind = cmd+[=goto_split:previous
keybind = cmd+w=close_surface
keybind = cmd+shift+up=resize_split:up,20
keybind = cmd+shift+down=resize_split:down,20
keybind = cmd+shift+left=resize_split:left,20
keybind = cmd+shift+right=resize_split:right,20

# Word traversal
keybind = opt+left=esc:b
keybind = opt+right=esc:f
keybind = opt+backspace=esc:ctrl+h
keybind = cmd+backspace=esc:ctrl+u


# Window transparency/blur
background-opacity = 0.75
background-blur-radius = 20

# Font ligatures
font-feature = calt
font-feature = liga

# Cursor
cursor-style = bar
cursor-style-blink = true
cursor-color = #F5C2E7

# URL

# Bell

# Auto update
auto-update = check
auto-update-channel = stable



# Multiple font fallbacks
font-family-bold = JetBrainsMono Nerd Font
font-family-italic = JetBrainsMono Nerd Font

# Minimum contrast for readability
minimum-contrast = 1.1

# Focus follows mouse (useful with splits)
focus-follows-mouse = false

# Quick terminal (like a dropdown)
keybind = global:super+grave_accent=toggle_quick_terminal

# Resize font quickly
keybind = super+equal=increase_font_size:1
keybind = super+minus=decrease_font_size:1

window-width = 220
window-height = 65
window-save-state = always
macos-titlebar-style = transparent

